PORT=7000

# PostgreSQL
# Use JDBC URL format. Example:
# DATABASE_URL=jdbc:postgresql://db-host:5432/bettercases?sslmode=require
DATABASE_URL=jdbc:postgresql://your-postgres-host:5432/bettercases?sslmode=require
DATABASE_USER=postgres
DATABASE_PASSWORD=changeme

# CORS and app URLs
# Exact origins (scheme + host, no path). Main app must match FRONTEND_URL.
CORS_ALLOWED_ORIGINS=https://app.example.com
FRONTEND_URL=https://app.example.com

# Auth/session
SESSION_DAYS=30

# Email (OTP and alerts)
POSTMARK_API_TOKEN=
POSTMARK_FROM_EMAIL=noreply@example.com

# Jira OAuth (optional)
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_REDIRECT_URI=https://app.example.com/jira/callback

# Knowledge Base file storage
# local: saves under /app/uploads (mounted to ./uploads in compose) — no further config needed.
# s3: stores in any S3-compatible service (AWS S3, DigitalOcean Spaces, MinIO, Cloudflare R2,
#     Backblaze B2, ...). Files are served via short-lived presigned URLs, never public links.
STORAGE_DRIVER=local
S3_BUCKET=
S3_REGION=us-east-1
# Only needed for non-AWS S3-compatible endpoints (DigitalOcean Spaces, MinIO, R2, etc.)
S3_ENDPOINT=
# Leave blank to use the default AWS credential chain (IAM role, shared config, etc.) instead.
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Set to true for MinIO and some other S3-compatible services.
S3_FORCE_PATH_STYLE=false
S3_PRESIGNED_URL_TTL_SECONDS=600
