# Copy to .env and adjust for non-local targets. Every value has a sensible default for
# the local docker-compose stack, so this file is optional for local runs.

API_BASE_URL=http://localhost:1011
WEB_BASE_URL=http://localhost:1010

# Disposable smoke-test account. On a fresh stack this user doesn't exist yet — global
# setup creates it automatically (see E2E_AUTO_PROVISION below).
E2E_TEST_EMAIL=e2e-smoke@tesbo.local
E2E_TEST_PASSWORD=E2eSmokeTest!2026
E2E_TEST_NAME=E2E Smoke User

E2E_ORG_NAME=E2E Smoke Org
E2E_PROJECT_NAME=E2E Smoke Project

# Second, independent tenant used only by e2e/api/authorization.spec.ts (the cross-tenant
# authorization regression suite) to prove account B can't reach account A's resources.
E2E_TEST_EMAIL_B=e2e-smoke-b@tesbo.local
E2E_TEST_PASSWORD_B=E2eSmokeTestB!2026
E2E_TEST_NAME_B=E2E Smoke User B
E2E_ORG_NAME_B=E2E Smoke Org B
E2E_PROJECT_NAME_B=E2E Smoke Project B

# Defaults to true when API_BASE_URL is localhost/127.0.0.1, false otherwise. Signup
# requires an OTP that (with no Postmark token configured) is only printed to the backend
# container's stdout, so auto-provisioning scrapes it from `docker compose logs`. Against a
# remote target, either pre-create E2E_TEST_EMAIL/E2E_TEST_PASSWORD yourself and leave this
# false, or set it to true only if you also have docker log access to that host.
E2E_AUTO_PROVISION=

E2E_DOCKER_COMPOSE_FILE=
E2E_DOCKER_SERVICE=backend
