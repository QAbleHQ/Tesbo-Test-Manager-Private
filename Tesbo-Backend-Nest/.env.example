PORT=7000
DATABASE_URL=postgresql://localhost:5432/tesbo
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
POSTMARK_API_TOKEN=
POSTMARK_FROM_EMAIL=noreply@example.com
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_WINDOW_MINUTES=15
SESSION_DAYS=30
CORS_ALLOWED_ORIGINS=http://localhost:1010,http://127.0.0.1:1010,http://localhost:3000,http://127.0.0.1:3000
FRONTEND_URL=http://localhost:1010
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_REDIRECT_URI=http://localhost:1010/integrations/callback
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
LINEAR_REDIRECT_URI=http://localhost:1010/integrations/callback
# AES-256-GCM key used to encrypt integration secrets (OAuth tokens, personal access tokens)
# at rest. Generate with: openssl rand -base64 32
SECRETS_ENCRYPTION_KEY=
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=52428800
# Object storage for Knowledge Base files. Defaults to local disk (UPLOAD_DIR above).
# Set STORAGE_DRIVER=s3 to use any S3-compatible service (AWS S3, MinIO, Cloudflare R2,
# DigitalOcean Spaces, Backblaze B2, ...). Files are stored under a per-project prefix
# (knowledge-base/<organizationId>/<projectId>/...) and are only ever served via short-lived presigned URLs
# issued after the request passes project access + role checks.
STORAGE_DRIVER=local
S3_BUCKET=
# Optional key prefix so multiple environments can share one bucket without colliding.
S3_BUCKET_FOLDER=
S3_REGION=us-east-1
# Only needed for non-AWS S3-compatible endpoints (MinIO, R2, Spaces, etc.)
S3_ENDPOINT=
# Omit to use the default AWS credential chain (IAM role, shared config, etc.)
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Set to true for MinIO and some other S3-compatible services
S3_FORCE_PATH_STYLE=false
# How long a signed download/preview link stays valid.
S3_PRESIGNED_URL_TTL_SECONDS=300
